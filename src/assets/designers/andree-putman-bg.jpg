    		}

    		if(formId == 5){
				var is_in_china = localStorage.getItem('is_in_china');
				if(is_in_china != 'yes'){
					window.dataLayer = window.dataLayer || [];
					window.dataLayer.push({
						'event': 'FormStylesubmission',
						'eventCategory': 'Stylisme service submission'
					});
				}
                /*console.log('Styling services');
				console.log(window.dataLayer.push({
    				'event': 'FormStylesubmission',
    				'eventCategory': 'Stylisme service submission'
    			}));*/
    		}
		});

		jQuery(document).on('click','.vsz-product-container',function(){
			var is_in_china = localStorage.getItem('is_in_china');
			if(is_in_china != 'yes'){
				dataLayer.push({
					'event': 'productClick',
					'productClick': [
						{
							'id': jQuery(this).data('product_id'),
							'parent_sku': jQuery(this).data('parent_sku'),
							'name': jQuery(this).data('product_name'),
							'startingFromPriceHT': jQuery(this).data('startingfrompriceht'),
							'startingFromPriceALLTAX': jQuery(this).data('startingfrompricealltax'),
							'price': jQuery(this).data('price'),
							'category1': jQuery(this).data('category1'),
							'categoryPrimary': jQuery(this).data('categoryprimary'),
							'designer': jQuery(this).data('designer'),
							'tags': jQuery(this).data('tags'),
							'position': jQuery(this).data('product_index'),
						}
					]
				});
			}
		});

		function vsz_ga_remove_cart_product(chref,cart_hash){
			var obj = {
				'action': 'vsz_ga_remove_cart',
				'cart_hash' : cart_hash,
			};

			jQuery.ajax({
				url : 'https://theinvisiblecollection.com/wp-admin/admin-ajax.php',
				type : 'POST',
				data : obj,
				success : function(response){
					if(response != ""){
						var result = JSON.parse(response);
						var is_in_china = localStorage.getItem('is_in_china');
						if(is_in_china != 'yes'){
							dataLayer.push({
								'event': 'productRemove',
								'productRemove': [
								{
									'id':  result.productRemove.id,
									'parent_sku': result.productRemove.parent_sku,
									'name': result.productRemove.name,
									'category1': result.productRemove.category1,
									'categoryPrimary': result.productRemove.categoryPrimary,
									'designer': result.productRemove.designer,
									'startingFromPriceHT': result.productRemove.startingFromPriceHT,
									'startingFromPriceALLTAX': result.productRemove.startingFromPriceALLTAX,
									'price': result.productRemove.price,
									'quantity': result.productRemove.quantity,
									'composition': result.productRemove.composition,
									'size': result.productRemove.size,
									'availability': result.productRemove.availability,
									'tags': result.productRemove.tags,
								}
								]
							});
						}
						window.location.href = chref;
					}
				}
			});
		}

		/*EXecution on page scroll*/
		function vsz_execute_data_layer_for_ga(layerObj){
			/*Clear the previous ecommerce object.*/
			/*dataLayer.push({ ecommerce: null });*/
			var result = JSON.parse(layerObj);
			if(result.productImpressions.length > 0){
				var product_list = [];
				var product_info = result.productImpressions;
				for(var i=0;i<result.productImpressions.length;i++){
					product_list[i] = {
						'id': result.productImpressions[i].id,
						'parent_sku': result.productImpressions[i].parent_sku,
						'name': result.productImpressions[i].name,
						'startingFromPriceHT': result.productImpressions[i].startingFromPriceHT,
						'startingFromPriceALLTAX': result.productImpressions[i].startingFromPriceALLTAX,
						'price': result.productImpressions[i].price,
						'category1': result.productImpressions[i].category1,
						'categoryPrimary': result.productImpressions[i].categoryPrimary,
						'designer': result.productImpressions[i].designer,
						'tags': result.productImpressions[i].tags,
						'position': result.productImpressions[i].position,
                        'list' : 'Table',
					};
				}
				var is_in_china = localStorage.getItem('is_in_china');
				if(is_in_china != 'yes'){
					dataLayer.push({
						'event': 'productImpressions',
						'productImpressions': product_list,
					});
				}
			}
		}
		</script>
				<script type="rocketlazyloadscript" id="wppl-precheck-remember-me">
		(function() {
			'use strict';
			
			var wppl_precheck_remember_me = function() {
				var rememberMeNames = ["rememberme","remember","rcp_user_remember"];
				var processedElements = new Set(); // Track processed elements to avoid duplicates
				
				/**
				 * Check/enable a checkbox element
				 */
				function checkElement(element) {
					if (processedElements.has(element)) return;
					processedElements.add(element);
					
					if (element.type === 'checkbox' && !element.checked) {
						element.checked = true;
					}
				}
				
				/**
				 * Process standard remember me inputs
				 */
				function processRememberMeElements() {
					rememberMeNames.forEach(function(inputName) {
						// Find inputs by exact name match
						var inputs = document.querySelectorAll('input[name="' + inputName + '"]');
						inputs.forEach(function(input) {
							checkElement(input);
						});
						
						// Also find inputs where name contains the input name (partial match)
						var partialInputs = document.querySelectorAll('input[type="checkbox"]');
						partialInputs.forEach(function(input) {
							if (input.name && input.name.includes(inputName)) {
								checkElement(input);
							}
						});
					});
				}
				
				/**
				 * Handle WooCommerce specific elements
				 */
				function processWooCommerce() {
					var wooInputs = document.querySelectorAll('.woocommerce-form-login__rememberme input[type="checkbox"]');
					wooInputs.forEach(function(input) {
						checkElement(input);
					});
				}
				
				/**
				 * Handle Ultimate Member Plugin
				 */
				function processUltimateMember() {
					var umCheckboxLabels = document.querySelectorAll('.um-field-checkbox');
					
					umCheckboxLabels.forEach(function(label) {
						var input = label.querySelector('input');
						if (input && rememberMeNames.includes(input.name)) {
							// Set as active and checked
							checkElement(input);
							label.classList.add('active');
							
							// Update icon classes
							var icon = label.querySelector('.um-icon-android-checkbox-outline-blank');
							if (icon) {
								icon.classList.add('um-icon-android-checkbox-outline');
								icon.classList.remove('um-icon-android-checkbox-outline-blank');
							}
						}
					});
				}
				
				/**
				 * Handle ARMember Forms
				 */
				function processARMember() {
					var armContainers = document.querySelectorAll('.arm_form_input_container_rememberme');
					
					armContainers.forEach(function(container) {
						var checkboxes = container.querySelectorAll('md-checkbox');
						
						checkboxes.forEach(function(checkbox) {
							if (checkbox.classList.contains('ng-empty')) {
								checkbox.click(); // Activate the checkbox
							}
						});
					});
				}
				
				// Execute all processing functions
				processRememberMeElements();
				processWooCommerce();
				processUltimateMember();
				processARMember();
			};
			
			// Run when DOM is ready
			if (document.readyState === 'loading') {
				document.addEventListener('DOMContentLoaded', wppl_precheck_remember_me);
			} else {
				wppl_precheck_remember_me();
			}
			
			// Also run after a short delay to catch dynamically loaded forms
			setTimeout(wppl_precheck_remember_me, 500);
			
		})();
		</script>
		
