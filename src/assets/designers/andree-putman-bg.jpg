				jQuery('body').addClass('mb-menu-open');
			}
		});
		jQuery('.mobile-menu-toogle .header-side-menu .contact-list .sub-menu-link').on("click", function(){
			jQuery(this).parent().toggleClass('menu-open');
		});
		jQuery('.mobile-menu-toogle .header-side-menu .menu-btn,.mobile-menu-toogle .header-side-menu .contact-list .mega-sub-menu .menu-back-btn').on("click", function(){
			jQuery('.mobile-menu-toogle .header-side-menu .contact-list .sub-menu-link').parent().removeClass('menu-open');
		});
		jQuery('.mobile-menu-toogle .header-side-menu .menu-btn').on("click", function(){
			jQuery('.right-content-outer .boxlink').removeClass('active-submenu');
		});
		
		var variationsL = jQuery(".variations td.label label").length;
		if(variationsL > 0){
			jQuery('body .variations td.label label').click(function(){
				jQuery(this).parent().next().slideToggle('medium', function() {
				if (jQuery(this).is(':visible'))
					jQuery(this).css('display','block');
				});
				jQuery(this).toggleClass('active');
			});
		}
	
	});
	
	</script>
