		    <script nowprocket="1" type="1d4f8ac07288f620e7efa3ed-text/javascript">
        // Check for the country and currency settings
        const wcpbcCurrencyCustom = "wcpbc_currency_custom";
        const wcpbcCountryCustom = "wcpbc_country_custom";
        const currentCountryName = "currentcountry_name";
        const userRole = "user_role";
        const switcherLink = "https://theinvisiblecollection.com/switcher-settings/";

        const getCookieValue = (name) => {
            const match = document.cookie.match(RegExp('(?:^|;\\s*)' + name + '=([^;]*)'));
            return match ? decodeURIComponent(match[1]) : null;
        };

        const currentCurrency = getCookieValue(wcpbcCurrencyCustom);
        const currentCountry = getCookieValue(wcpbcCountryCustom);
        const wcpbccurrentCountryName = getCookieValue(currentCountryName);
        const userRoleData = getCookieValue(userRole);
		
		
        // Handle country and currency settings
        if (currentCountry && currentCurrency) {
			const safeCountryName = wcpbccurrentCountryName ? wcpbccurrentCountryName.split("+").join(" ") : currentCountry; // fallback to country code
            const countryLink = `<a href="${switcherLink}" title="${safeCountryName}">
                                    <span class="c-icon flag flag-${currentCountry.toLowerCase()}">${currentCountry}</span>
                                </a>`;
            const currencyLink = `<a href="${switcherLink}">${currentCurrency}</a>`;

            const updateElementContent = (id, content) => {
                const el = document.getElementById(id);
                if (el) el.innerHTML = content;
            };

            // Update country and currency data in the DOM
            updateElementContent("country_data", countryLink);
            updateElementContent("currency_data", currencyLink);
            updateElementContent("country_data_mobile", countryLink);
            updateElementContent("currency_data_mobile", currencyLink);

            const headerLoader = document.querySelector('.header-loader-switch');
            if (headerLoader) {
                headerLoader.style.visibility = 'visible';
                headerLoader.style.opacity = '1';
            }
        }

        // Handle user role-based UI adjustments
        if (userRoleData) {
            // Hide guest icon and show login user icon
            document.querySelectorAll(".guest-user-icon").forEach(el => el.style.display = 'none');
            document.querySelectorAll(".login-user-icon").forEach(el => el.style.display = 'block');
            
            // Hide account login and show user logged-in section
            document.querySelectorAll(".account-login").forEach(el => el.style.display = 'none');
            document.querySelectorAll(".user-logged-in").forEach(el => el.style.display = 'block');
            
            // Show or hide admin bar based on specific user roles
            const userRolesAllowed = ['administrator', 'contentteam', 'sales'];
            if (userRolesAllowed.some(role => userRoleData.includes(role))) {
                //document.getElementById("wpadminbar").style.display = 'block';
                //document.getElementById("wp-admin-bar-top-secondary").style.display = 'none';
            } else {
                const wpadminbar = document.getElementById("wpadminbar");
                if (wpadminbar) wpadminbar.remove();
                
                const adminBarHeader = document.querySelector('.admin-bar .header');
                if (adminBarHeader) {
                   // adminBarHeader.style.top = "0px";
                }
                document.body.classList.remove('admin-bar');
            }
        } else {
            const wpadminbar = document.getElementById("wpadminbar");
            if (wpadminbar) wpadminbar.remove();
            const adminBarHeader = document.querySelector('.admin-bar .header');
            if (adminBarHeader) {
                //adminBarHeader.style.top = "0px";
            }
            document.body.classList.remove('admin-bar');
        }
		
    </script>
	<script nowprocket="1" type="1d4f8ac07288f620e7efa3ed-text/javascript">
		jQuery(document).ready(function(){
