		jQuery(document).ready(function($) {
			// Function to check if all billing fields are filled
			function checkBillingFields() {
				var allFieldsFilled = true;
				console.log('All billing fields are checked....');
				// Check if all required billing fields are filled
				$('input#billing_first_name, input#billing_last_name, input#billing_email, input#billing_phone,input#shipping_first_name, input#shipping_last_name, input#shipping_email, input#shipping_phone').each(function() {
					if ($(this).val() === '') {
						allFieldsFilled = false;
						return false; // Break out of the loop
					}
				});
				return allFieldsFilled;
			}

			// Trigger update when all billing fields are filled
			$('#ship-to-different-address-checkbox, input.vsz_shipping_method_field').on('click', function() {
				// All billing fields are filled, trigger update
					// You can trigger an AJAX call or perform any other action here
					console.log('Triggering update...');
					jQuery(document.body).trigger("update_checkout");
                    return true;
			});
			// Trigger update when all billing fields are filled
			$('input#billing_postcode').on('change', function() {
				if (jQuery("#ship-to-different-address-checkbox").prop('checked') == false) {
					// All billing fields are filled, trigger update
					// You can trigger an AJAX call or perform any other action here
					console.log('All billing fields are filled. Triggering update...');
					jQuery(document.body).trigger("update_checkout");
                    return true;
				}
			});
			$('input#shipping_postcode').on('change', function() {
				if (jQuery("#ship-to-different-address-checkbox").prop('checked') == true) {
					// All billing fields are filled, trigger update
					// You can trigger an AJAX call or perform any other action here
					console.log('All shipping fields are filled. Triggering update...');
					jQuery(document.body).trigger("update_checkout");
                    return true;
				}
			});
		});
    </script>
    <script type="rocketlazyloadscript" data-minify="1" data-rocket-src="https://theinvisiblecollection.com/wp-content/cache/min/1/js/apis/geoip2/v2.1/geoip2.js?ver=1762863353" data-rocket-type="text/javascript"></script>
<script type="rocketlazyloadscript" data-rocket-type="text/javascript">
var vsz_site_uri = "https://theinvisiblecollection.com/";
var redirect = (function () {
    /* This implements the actual redirection. */
    var redirectBrowser = function (site) {
        if( site != "" ){
            var uri = "https://theinvisiblecollection.com/"+site+"/";
            window.location = uri;
        }
    };

    /* These are the country codes for the countries we have sites for.
     * We will check to see if a visitor is coming from one of these countries.
     * If they are, we redirect them to the country-specific site. If not, we
     * redirect them to world.example.com */
    var sites = {
        //"de": true,
        "fr": true,
        //"gb": true,
        //"us": true
    };
    var defaultSite = "";

    var onSuccess = function (geoipResponse) {
        /* There's no guarantee that a successful response object
         * has any particular property, so we need to code defensively. */
        /*if (!geoipResponse.country.iso_code) {
            redirectBrowser(defaultSite);
            return;
        }*/
        //console.log("Geoip Country code : "+geoipResponse.country.iso_code);
       // console.log("Cookiee Value : "+VSZgetCookie('geoIpredirect'));
        /* ISO country codes are in upper case. */
        var code = geoipResponse.country.iso_code.toLowerCase();

        if ( sites[code] && VSZgetCookie('geoIpredirect') !== 'true' ) {
            document.cookie = "geoIpredirect=true";
            //console.log(window.location.href);
            //console.log(vsz_site_uri);
            //console.log(window.location.href == vsz_site_uri);
            if( window.location.href == vsz_site_uri ){
                redirectBrowser(code);
            }
        }
        /*else {
            redirectBrowser(defaultSite);
        }*/
    };

    /* We don't really care what the error is, we'll send them
     * to the default site. */
    var onError = function (error) {
        //redirectBrowser(defaultSite);
    };

    return function () {
        geoip2.country( onSuccess, onError );
    };
}());
function VSZgetCookie(name) {
    // Split cookie string and get all individual name=value pairs in an array
    var cookieArr = document.cookie.split(";");

    // Loop through the array elements
    for(var i = 0; i < cookieArr.length; i++) {
        var cookiePair = cookieArr[i].split("=");

        /* Removing whitespace at the beginning of the cookie name
        and compare it with the given string */
        if(name == cookiePair[0].trim()) {
            // Decode the cookie value and return
            return decodeURIComponent(cookiePair[1]);
        }
    }

    // Return null if not found
    return null;
}
jQuery(document).ready(function($) {
	redirect();
});

var vsz_current_wpml_lang = "en";
