	const SESSION_LIFETIME_MS = 24 * 60 * 60 * 1000; // 24 hours
	function isSessionExpired(session) {
		return (
			!session ||
			(Date.now() - session > SESSION_LIFETIME_MS)
		);
	}
	function geoip(json){
		//alert(json.ip);
		var country = json.country_code;
		var bannedCountries = ['CN','HK'];
		let session_created_at = localStorage.getItem('created_at');
		if(isSessionExpired(session_created_at)){
			if(bannedCountries.includes(country)){
				localStorage.setItem('is_in_china', 'yes');
				localStorage.setItem('created_at', Date.now());
			}else{
				localStorage.removeItem('is_in_china');
				localStorage.removeItem('created_at');
			}
		}
	}
</script>
		
