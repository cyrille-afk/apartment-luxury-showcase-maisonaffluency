			const renderSearchBoxHeader = (renderOptions, isFirstRender) => {
				const { query, refine, clear, isSearchStalled, widgetParams } = renderOptions;

				// Debounce function
				function debounce(func, wait) {
					let timeout;
					return function(...args) {
						clearTimeout(timeout);
						timeout = setTimeout(() => func.apply(this, args), wait);
					};
				}

				if (isFirstRender) {
					const input = widgetParams.container;
					const debouncedRefine = debounce(function(event) {
						refine(event.target.value);
					}, 500); // 150ms debounce

					input.addEventListener('input', debouncedRefine);
				}
			};
