<script type="rocketlazyloadscript">
jQuery(document).ready(function(){
	const $slider = jQuery('.hp-shorooms-row');
	const itemCount = $slider.children('.showroom-box').length;

	if (itemCount <= 5) {
		$slider.addClass('less-than-6');
	} else {
		$slider.addClass('greter-than-5');
	}
	
	setTimeout(function() {
	jQuery('.hp-shorooms-row').not('.slick-initialized').slick({
		  slidesToShow: 5.5,
		  slidesToScroll: 5,
		  arrows: true,
		  infinite:false,
		  dots: true,
	      draggable: true,
		  swipe: true,
		  touchMove: true,
		  touchThreshold: 20,
		  speed: 300,
		  cssEase: 'ease-in-out',
		  lazyLoad: 'ondemand',
		  prevArrow:'<span class="post-prev custom-arrow"></span>',
          nextArrow:'<span class="post-next custom-arrow"></span>',
		  responsive: [
			  {
			  breakpoint: 1200,
			  settings: {
				slidesToShow: 4,
				slidesToScroll: 4,
				   dots: true,
			  }
			},
			{
			  breakpoint: 1040,
			  settings: {
				slidesToShow: 3,
				slidesToScroll: 3,
				   dots: true,
			  }
			},
			{
			  breakpoint: 767,
			  settings: {
				slidesToShow: 2,
				slidesToScroll: 2,
				   dots: true,
			  }
			},
			{
			  breakpoint: 576,
			  settings: {
				slidesToShow: 1,
				slidesToScroll: 1,
				   dots: true,
			  }
			},
		   ]
		});
	}, 500);
	
});
</script>
