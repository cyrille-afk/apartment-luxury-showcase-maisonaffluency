						jQuery(".show-price").hide();
						jQuery(".tic-wctc-pro-stc").hide();
						jQuery(".tic-wctc-stc").hide();
					}
				}, 1000);
            });
			var ids = [];
            var user_role = "user_role";
            var $user_role = document.cookie.match(RegExp('(?:^|;\\s*)' + user_role + '=([^;]*)'));
			
			if( $user_role ){
				var userRole1 = 'sales'; // Array of roles to check
				var userRole2 = 'sales_limited_access'; // Array of roles to check
				// Get the cookie value (it will be in the first capture group)
				var salesUserRoles = JSON.parse(decodeURIComponent($user_role[1]));
				var UserRoles = Object.values(salesUserRoles);
				console.log('userRole1');
				console.log(UserRoles.includes(userRole1));
				console.log('userRole2');
				console.log(UserRoles.includes(userRole2));
				if( UserRoles.includes(userRole1) || UserRoles.includes(userRole2) ){
					jQuery("#extra-sales-info").css('display','block');
				}else{
					jQuery("#extra-sales-info").css('display','none');
					jQuery("#sales-loader").css('display','none');
					jQuery(".pro-convelio-sec").remove();
				}
			}else{
				jQuery("#extra-sales-info").css('display','none');
				jQuery("#sales-loader").css('display','none');
				jQuery(".pro-convelio-sec").remove();
			}
			
			if(jQuery('body').hasClass('single-product')){
				var ajaxdata = {
			  'action': 'vsz_show_hide_on_load',
			  'product_id' : convelio_ajax_param.product_id,
			  'product_type' : convelio_ajax_param.product_type,
			  'is_virtual' : convelio_ajax_param.is_virtual,
			};
			jQuery.ajax({
			  url: 'https://theinvisiblecollection.com/wp-content/themes/tic/showhidecalcshippingbutton.php',
			  type : 'POST',
			  data : ajaxdata,
			  success : function(response){
				if(response != ""){
					jQuery("#calculate-shipping-btn").css('display',response.convelio_btn_display);
				}else{
					jQuery("#calculate-shipping-btn").css('display','none');
				}
			  }
			});
				var main_product_id = jQuery('form.js-add-to-cart-form').data('product_id');
				if ( typeof main_product_id === 'undefined' ) {
					main_product_id = jQuery('form.js-add-to-cart-form button.single_add_to_cart_button').data('product_id');
