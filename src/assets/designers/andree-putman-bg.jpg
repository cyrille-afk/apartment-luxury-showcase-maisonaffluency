                                noRestultsFoundOverlay();
                                return container.querySelector('ul').innerHTML = '<li class="norsl-text-header">'+noResultsTemplateHeader+' <strong>'+searchTermData+'</strong>.</div></li>';
                            }else{
                                jQuery(".no-results-box").hide();
                                jQuery("#resultProducts").show();
                            }
							var is_in_china = localStorage.getItem('is_in_china');
							if(is_in_china != 'yes'){
								window.dataLayer = window.dataLayer || [];
								dataLayer.push({
									'event': 'FormSearch',
									'eventCategory': 'Search submission',
									'eventAction': renderArgs.results.query,
									'eventLabel': hits.length
								});
							}
                            container.querySelector('ul').innerHTML = hits
                                .map(function(hit) {
                                    //console.log(hit);
                                    var image = 'https://theinvisiblecollection.com/wp-content/themes/tic/static/img/no-pro-img.jpg';
                                    if(hit.image){
                                        image = hit.image;
                                    }
									if(hit.clubroom_acf_product_list_image){
                                        image = hit.clubroom_acf_product_list_image;
                                    }
                                    var template = '<li class="ais-Hits-item"><div class="product-image">' + '<div class="pro-img-item"><a href="'+hit.permalink+ '"><img data-lazyloaded="1"       data-placeholder-resp="176x176" src="'+image+'" /></a></div>' +
                '</div>' +
                '<div class="product-name"><a href="'+ hit.permalink+ '" >'+ hit.post_title+'</a></div></li>';

                                    return template;

                                }).join('');

                    });

					//ruleContexts starts
                    let getPageType = function() {
                        let currentPath = window.location.pathname;
                        let pageType = 'categoryPage';
                        if (currentPath === '/') {
                            pageType = 'homePage';
                        } else if (currentPath.startsWith('/products/') || window.location.pathname.startsWith('/fr/produits/')) {
                            pageType = 'productsPage';
                        } else if (currentPath.startsWith('/designer/') || window.location.pathname.startsWith('/fr/portrait/')) {
                            pageType = 'designersPage';
                        } else if (currentPath.startsWith('/products-category/designer') || currentPath.startsWith('/fr/produits-categorie/designer')) 						   {
                            pageType = 'designerPage';
                        }
                        return pageType;
                    }

                    let pageTypeTag = getPageType();
                    let getUserType = function(){
                        return 'audience_'+search_user_roles;
                    }

                    let userTypeTag = getUserType();
                    let getCookie = function(cname) {
                        let name = cname + "=";
                        let decodedCookie = decodeURIComponent(document.cookie);
                        let ca = decodedCookie.split(';');
                        for(let i = 0; i <ca.length; i++) {
                            let c = ca[i];
                            while (c.charAt(0) == ' ') {
                                c = c.substring(1);
                            }
                            if (c.indexOf(name) == 0) {
                                return c.substring(name.length, c.length);
                            }
                        }
                        return "";
                    }
                    let getCountryTag = function(){
                        return `country_${getCookie('wcpbc_country_custom')}`;
                    }
                    let countryTag = getCountryTag();
                    let getDeviceType = function(){
                        const ua = navigator.userAgent;
                        if (/(tablet|ipad|playbook|silk)|(android(?!.*mobi))/i.test(ua)) {
                            return "tablet";
                        }
                        else if (/Mobile|Android|iP(hone|od)|IEMobile|BlackBerry|Kindle|Silk-Accelerated|(hpw|web)OS|Opera M(obi|ini)/.test(ua)) {
                            return "mobile";
                        }
                        return "desktop";
                    };
                    let getDeviceTypeTag = function(){
                        return `device_type_${getDeviceType()}`;
                    }
                    let deviceTypeTag = getDeviceTypeTag();
                    let ruleContexts = [pageTypeTag, userTypeTag, countryTag, deviceTypeTag];

                    searchHeader.addWidgets(
                        [
                            instantsearch.widgets.configure({
                                ruleContexts: ruleContexts,
                            }),
                        	/*instantsearch.widgets.searchBox({
                                container: '.searchbox',
                                placeholder: "Search",
                                searchAsYouType: true,
                                autofocus: true,
                            }),*/
                            // instantiate custom widget
                            /**customSearchBoxHeader({
                                container: document.querySelector('#custom-search'),
                            }),*/
                            /*customSearchBoxHeader({
                                container: document.querySelector('#custom-search'),
                            }),*/
                            /*customRefinementListHeader({
                                attribute: 'product_cat',
                                limit: '10',
                            }),
                            customRefinementListHeader2({
                                attribute: 'product_designer',
                                limit: '10',
                            }),*/
                            /*instantsearch.widgets.hits({
                                container: '.result-products',
                                transformItems: function (items) {
                                    console.log(items);
                                    return items.slice(0, 8);
                                },
                                templates: {
                                    //item: $('#resultProducts').html(),
                                    item: hitTemplate,
                                },
                            }),*/
                            customHitsHeader({

                                container: document.querySelector('#resultProducts'),
                                transformItems: function (items) {
                                    //console.log(items);
                                    return items.slice(0, 8);
                                },
                            })
                        ]
                    );
					if( is_clubroom_page == "1" ){
                        //jQuery("#resultDesigners").hide();
                        searchHeader.addWidgets(
				            [
                                customSearchBoxHeader({
                                    container: document.querySelector('#new-clubroom-search'),
                                }),
                                customRefinementListHeader({
                                    attribute: 'clubroom_taxonomies',
                                    limit: '10',
                                    sortBy: ['count:desc', 'name:asc'],
                                }),
                                customRefinementListHeader2({
                                    attribute: 'clubroom_product_designer',
                                    limit: '10',
                                })
                            ]
                        );
                    }else{
                        searchHeader.addWidgets(
				            [
                                
                                // instantiate custom widget
                                customSearchBoxHeader({
                                    container: document.querySelector('#custom-search'),
                                }),
                                customRefinementListHeader({
                                    attribute: 'product_cat',
                                    limit: '10',
                                    sortBy: ['count:desc', 'name:asc'],
                                }),
                                customRefinementListHeader2({
                                    attribute: 'product_designer',
                                    limit: '10',
                                }),
                            ]
                        );
                    }
					//searchHeader.start();
                    jQuery('#custom-search').on('keyup', function(){
                        jQuery("#main-search-outter").show();
                    });
					jQuery('#new-clubroom-search').on('keyup', function(){
                        //alert("New clubroom search box");
				    	jQuery("#main-search-outter").show();
				    });
                    
                    jQuery.fn.changeWord = function (str, className) {
                        var regex = new RegExp(str, "gi");
                        return this.each(function () {
                            this.innerHTML = this.innerHTML.replace(regex, function(matched) {
                                return "<span class='" + className + "'>" + matched + "</span>";
                            });
                        });
                    };
                });
            }

         /*$(document).on("keypress", e => {
            if (e.key == "Enter") searchPage()
        });*/
        //$('.ais-SearchBox-submit').on('click', searchPage);

        function searchPage() {
            var currentQuery = jQuery(".search-input").find("input").val();
            var srcValue = jQuery('.ais-SearchBox-input').val();
            var searchUrl = 'https://clubroom.theinvisiblecollection.com';
            if (srcValue == "" || srcValue == null || srcValue == undefined) {
                window.location.href = searchUrl + "/?s=&query=";
            } else {
                window.location.href = searchUrl + "/?s=" + currentQuery + "&query=" + currentQuery;
            }
        }

        jQuery(".seeAllCta").click(function (event) {
            event.preventDefault();
            var seeAllBtnLink = jQuery(this).attr("href");
            var refinementLink = jQuery(this).attr("data-refinementLink");
            var currentQuery = jQuery("#custom-search").val();
            if (refinementLink == "category") {
                if (currentQuery == "" || currentQuery == null || currentQuery == undefined) {
                    window.location.href = seeAllBtnLink;
                } else {
                    window.location.href = seeAllBtnLink + "/?query=" + currentQuery;
                }
            }
            else if (refinementLink == "designers") {
                window.location.href = seeAllBtnLink;

            }
        })

        //noResultSearchHeaderOverlay.start();
        //noResultSearch.start();
        //searchHeader.start();
        jQuery(".search-pro-icon, .club-search-icon").click(function (event) {
			
			noResultSearchHeaderOverlay.start();
			searchHeader.start();
		});
        //Newly implemented code for the new search to be implemented ends
        //jQuery('#custom-search').on('keyup', noRestultsFoundOverlay);

            function noRestultsFoundOverlay() {

                    //if (jQuery("#resultProducts .ais-Hits--empty")[0]) {
                        const customNoHitsHeader = instantsearch.connectors.connectHits(
                        (renderArgs, isFirstRender) => {
                            const { hits, results, sendEvent, widgetParams } = renderArgs;
                            const { container } = widgetParams;
                            if (isFirstRender) {

                            }

                            container.querySelector('ul').innerHTML = hits.map(function(hit) {
                                    var image = 'https://theinvisiblecollection.com/wp-content/themes/tic/static/img/no-pro-img.jpg';
                                    if(hit.image){
                                        image = hit.image;
                                    }
									if(hit.clubroom_acf_product_list_image){
                                        image = hit.clubroom_acf_product_list_image;
                                    }
                                    var template = '<li class="ais-Hits-item"><div class="product-image">' + '<div class="pro-img-item"><a href="'+hit.permalink+ '"><img data-lazyloaded="1"       data-placeholder-resp="176x176" src="'+image+'" /></a></div>' +
                '</div>' +
                '<div class="product-name"><a href="'+ hit.permalink+ '" >'+ hit.post_title+'</a></div></li>';

                                    return template;

                                }).join('');

                    });

                        noResultSearchHeaderOverlay.addWidgets(
                            [
                                instantsearch.widgets.searchBox({
                                    container: "#searchbox2",
                                    cssClasses: "d-none"
                                }),
                                
                                customNoHitsHeader({
                                    container: document.querySelector('#noResultProductsContainerheader'),
                                    transformItems: function (items) {
                                        //console.log(items);
                                        return items.slice(0, 8);
                                    },
                                })
                            ]
                        );

                        noResultSearchHeaderOverlay.setUiState(noresult_initial_state);

                    //}
                    //else if (!jQuery(".ais-Hits--empty")[0]) {
                        //document.getElementById("noResultProductsContainerheader").innerHTML = "";
                    //}

            }
            //End of new implementeation

            }
            jQuery(document).ready(function($) {
                initializeAlgolia();
      });
        </script>
